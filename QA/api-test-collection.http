### ============================================
### 테이블오더 API 테스트 모음
### 기준: component-methods.md
### 사용법: VS Code REST Client 확장 또는 IntelliJ HTTP Client
### ============================================

@baseUrl = http://localhost:8080/api/v1
@adminToken = {{login_admin.response.body.token}}
@tableToken = {{login_table.response.body.token}}

### ============================================
### 0. 헬스체크
### ============================================

### 서버 상태 확인
GET {{baseUrl}}/health

### ============================================
### 1. AUTH — 인증
### ============================================

### 1-1. 관리자 로그인
# @name login_admin
POST {{baseUrl}}/auth/admin/login
Content-Type: application/json

{
  "storeCode": "STORE001",
  "username": "admin",
  "password": "admin1234"
}

### 1-2. 테이블 디바이스 로그인
# @name login_table
POST {{baseUrl}}/auth/table/login
Content-Type: application/json

{
  "storeCode": "STORE001",
  "tableNumber": 1,
  "tablePassword": "table1234"
}

### 1-3. 토큰 갱신
POST {{baseUrl}}/auth/refresh
Authorization: Bearer {{adminToken}}

### 1-4. [실패] 잘못된 비밀번호로 관리자 로그인
POST {{baseUrl}}/auth/admin/login
Content-Type: application/json

{
  "storeCode": "STORE001",
  "username": "admin",
  "password": "wrongpassword"
}

### 1-5. [실패] 잘못된 매장 코드로 테이블 로그인
POST {{baseUrl}}/auth/table/login
Content-Type: application/json

{
  "storeCode": "INVALID",
  "tableNumber": 1,
  "tablePassword": "table1234"
}

### ============================================
### 2. STORE — 매장
### ============================================

### 2-1. 매장 정보 조회
GET {{baseUrl}}/stores/1
Authorization: Bearer {{adminToken}}

### ============================================
### 3. TABLE — 테이블
### ============================================

### 3-1. 테이블 목록 조회
GET {{baseUrl}}/tables
Authorization: Bearer {{adminToken}}

### 3-2. 테이블 등록 (초기 설정)
POST {{baseUrl}}/tables
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "number": 1,
  "name": "테이블 1",
  "password": "table1234"
}

### 3-3. 테이블 정보 수정
PUT {{baseUrl}}/tables/1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "VIP 테이블 1",
  "password": "newtable1234"
}

### 3-4. 현재 세션 정보 조회
GET {{baseUrl}}/tables/1/session
Authorization: Bearer {{tableToken}}

### 3-5. 테이블 이용 완료 (세션 종료)
POST {{baseUrl}}/tables/1/sessions/end
Authorization: Bearer {{adminToken}}

### ============================================
### 4. CATEGORY — 카테고리
### ============================================

### 4-1. 카테고리 목록 조회
GET {{baseUrl}}/categories
Authorization: Bearer {{tableToken}}

### 4-2. 카테고리 등록
POST {{baseUrl}}/categories
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "메인 메뉴",
  "displayOrder": 1
}

### 4-3. 카테고리 수정
PUT {{baseUrl}}/categories/1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "시그니처 메뉴",
  "displayOrder": 1
}

### 4-4. 카테고리 삭제
DELETE {{baseUrl}}/categories/1
Authorization: Bearer {{adminToken}}

### ============================================
### 5. MENU — 메뉴
### ============================================

### 5-1. 메뉴 목록 조회 (전체)
GET {{baseUrl}}/menus
Authorization: Bearer {{tableToken}}

### 5-2. 메뉴 목록 조회 (카테고리별)
GET {{baseUrl}}/menus?categoryId=1
Authorization: Bearer {{tableToken}}

### 5-3. 메뉴 상세 조회
GET {{baseUrl}}/menus/1
Authorization: Bearer {{tableToken}}

### 5-4. 메뉴 등록
POST {{baseUrl}}/menus
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "김치찌개",
  "price": 9000,
  "description": "돼지고기 김치찌개",
  "categoryId": 1,
  "displayOrder": 1
}

### 5-5. 메뉴 수정
PUT {{baseUrl}}/menus/1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "김치찌개 (매운맛)",
  "price": 10000,
  "description": "돼지고기 김치찌개 - 매운맛",
  "categoryId": 1,
  "displayOrder": 1
}

### 5-6. 메뉴 삭제
DELETE {{baseUrl}}/menus/1
Authorization: Bearer {{adminToken}}

### 5-7. 메뉴 순서 변경
PUT {{baseUrl}}/menus/order
Authorization: Bearer {{adminToken}}
Content-Type: application/json

[
  { "menuId": 1, "displayOrder": 2 },
  { "menuId": 2, "displayOrder": 1 }
]

### 5-8. 메뉴 이미지 업로드 (2MB 이하)
POST {{baseUrl}}/menus/1/image
Authorization: Bearer {{adminToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="file"; filename="menu.jpg"
Content-Type: image/jpeg

< ./test-data/sample-menu.jpg
--boundary--

### ============================================
### 6. ORDER — 주문
### ============================================

### 6-1. 주문 생성
# @name create_order
POST {{baseUrl}}/orders
Authorization: Bearer {{tableToken}}
Content-Type: application/json

{
  "tableId": 1,
  "sessionId": 1,
  "items": [
    { "menuId": 1, "quantity": 2 },
    { "menuId": 3, "quantity": 1 }
  ]
}

### 6-2. 현재 세션 주문 조회
GET {{baseUrl}}/orders?tableId=1&sessionId=1
Authorization: Bearer {{tableToken}}

### 6-3. 주문 상세 조회
GET {{baseUrl}}/orders/1
Authorization: Bearer {{tableToken}}

### 6-4. 주문 상태 변경 — 준비중
PATCH {{baseUrl}}/orders/1/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "PREPARING"
}

### 6-5. 주문 상태 변경 — 완료
PATCH {{baseUrl}}/orders/1/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "COMPLETED"
}

### 6-6. 주문 삭제 (관리자 직권)
DELETE {{baseUrl}}/orders/1
Authorization: Bearer {{adminToken}}

### 6-7. 관리자 대시보드 (테이블별 주문 현황)
GET {{baseUrl}}/orders/dashboard
Authorization: Bearer {{adminToken}}

### 6-8. 과거 주문 이력 조회
GET {{baseUrl}}/orders/history?tableId=1
Authorization: Bearer {{adminToken}}

### 6-9. 과거 주문 이력 조회 (날짜 필터)
GET {{baseUrl}}/orders/history?tableId=1&date=2026-04-08
Authorization: Bearer {{adminToken}}

### 6-10. [실패] 빈 주문 생성
POST {{baseUrl}}/orders
Authorization: Bearer {{tableToken}}
Content-Type: application/json

{
  "tableId": 1,
  "sessionId": 1,
  "items": []
}

### ============================================
### 7. RECOMMENDATION — 추천
### ============================================

### 7-1. 인구통계 데이터 저장 (주문 완료 후)
POST {{baseUrl}}/recommendations/demographic
Authorization: Bearer {{tableToken}}
Content-Type: application/json

{
  "orderId": 1,
  "gender": "MALE",
  "ageGroup": "TWENTIES"
}

### 7-2. 추천 메뉴 조회
GET {{baseUrl}}/recommendations?gender=MALE&ageGroup=TWENTIES
Authorization: Bearer {{tableToken}}

### 7-3. 추천 메뉴 조회 (데이터 부족 시 — 전체 인기 폴백)
GET {{baseUrl}}/recommendations?gender=FEMALE&ageGroup=TEENS
Authorization: Bearer {{tableToken}}

### ============================================
### 8. RATING — 별점
### ============================================

### 8-1. 별점 등록 (주문 완료 후)
POST {{baseUrl}}/ratings
Authorization: Bearer {{tableToken}}
Content-Type: application/json

{
  "orderId": 1,
  "ratings": [
    { "menuId": 1, "score": 5 },
    { "menuId": 3, "score": 4 }
  ]
}

### 8-2. 메뉴별 평균 별점 조회
GET {{baseUrl}}/ratings/menus/1
Authorization: Bearer {{tableToken}}

### 8-3. 전체 메뉴 평균 별점 목록
GET {{baseUrl}}/ratings/menus
Authorization: Bearer {{tableToken}}

### 8-4. [실패] 범위 초과 별점 등록
POST {{baseUrl}}/ratings
Authorization: Bearer {{tableToken}}
Content-Type: application/json

{
  "orderId": 1,
  "ratings": [
    { "menuId": 1, "score": 6 }
  ]
}

### ============================================
### 9. SSE — 실시간 이벤트 (브라우저에서 테스트)
### ============================================

### 9-1. SSE 스트림 구독 (관리자)
### 브라우저 콘솔에서 테스트:
### const es = new EventSource('http://localhost:8080/api/v1/sse/orders');
### es.onmessage = (e) => console.log(JSON.parse(e.data));
### es.addEventListener('NEW_ORDER', (e) => console.log('신규주문:', JSON.parse(e.data)));
### es.addEventListener('ORDER_STATUS_CHANGED', (e) => console.log('상태변경:', JSON.parse(e.data)));
### es.addEventListener('ORDER_DELETED', (e) => console.log('삭제:', JSON.parse(e.data)));
GET {{baseUrl}}/sse/orders
Authorization: Bearer {{adminToken}}
Accept: text/event-stream
